# ── Uplift – Environment Variables ──────────────────────────────

# A long random string used to sign cookies and CSRF tokens.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-real-secret

# SQLAlchemy database URL.  Default uses a local SQLite file.
# For PostgreSQL: postgresql+asyncpg://user:pass@host:5432/uplift
DATABASE_URL=sqlite+aiosqlite:///./uplift.db

# Password required to access the /admin dashboard.
ADMIN_PASSWORD=admin

# ── Tuning knobs ────────────────────────────────────────────────

# Maximum characters per message (10–500)
MAX_MESSAGE_LENGTH=200

# Minimum characters per message
MIN_MESSAGE_LENGTH=10

# Max message submissions per user per calendar day
MAX_SUBMISSIONS_PER_USER_PER_DAY=3

# Max submissions per IP per hour
MAX_SUBMISSIONS_PER_IP_PER_HOUR=10

# VADER compound-score threshold below which a message is flagged.
# Messages scoring below this are marked pending (needs admin review).
SENTIMENT_THRESHOLD=-0.3

# Number of recent days to avoid re-delivering the same message to a user.
DELIVERY_REPEAT_WINDOW_DAYS=30
